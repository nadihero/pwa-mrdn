# Required for Google login + cloud data
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase dashboard checklist:
# 1. Authentication → Providers → Google → enable (Client ID + Secret from Google Cloud)
# 2. Authentication → URL Configuration → Redirect URLs:
#    - http://localhost:3000/**
#    - https://YOUR_VERCEL_DOMAIN/**
# 3. Run supabase/schema.sql (user_id + RLS per authenticated user)
